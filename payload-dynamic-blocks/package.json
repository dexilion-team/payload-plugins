{
  "name": "@dexilion/payload-dynamic-blocks",
  "version": "3.84.1-alpha.0",
  "description": "Dynamic blocks for Payload CMS, allowing for flexible content structures.",
  "author": "Dexilion",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./WidgetField": {
      "types": "./src/components/WidgetField.tsx",
      "import": "./src/components/WidgetField.tsx",
      "default": "./src/components/WidgetField.tsx"
    },
    "./WidgetCell": {
      "types": "./src/components/WidgetCell.tsx",
      "import": "./src/components/WidgetCell.tsx",
      "default": "./src/components/WidgetCell.tsx"
    },
    "./parseWidgetFields": {
      "types": "./src/utils/parseWidgetFields.ts",
      "import": "./src/utils/parseWidgetFields.ts",
      "default": "./src/utils/parseWidgetFields.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./src/constants.ts",
      "default": "./src/constants.ts"
    },
    "./CraftjsWidgetField": {
      "types": "./src/components/CraftjsWidgetField.tsx",
      "import": "./src/components/CraftjsWidgetField.tsx",
      "default": "./src/components/CraftjsWidgetField.tsx"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "peerDependencies": {
    "@dexilion/payload-pms": "workspace:*",
    "@faceless-ui/modal": "3.0.0",
    "@payloadcms/translations": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "payload": "3.85.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "engines": {
    "node": "^25.9.0 || ^24.14.1 || ^22.22.2 ",
    "pnpm": "^9 || ^10"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@craftjs/core": "^0.2.12"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@eslint/eslintrc": "^3.3.5",
    "@faceless-ui/modal": "3.0.0",
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/db-sqlite": "3.85.2",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/translations": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@types/node": "24.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.2",
    "graphql": "^16.8.1",
    "monaco-editor": ">= 0.25.0 < 1",
    "next": "^16.2",
    "npm-run-all2": "^8",
    "payload": "3.85.2",
    "prettier": "^3.8.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "sharp": "^0.34.5",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "scripts": {
    "build": "run-s copyfiles build:types build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./WidgetField": {
        "types": "./dist/components/WidgetField.d.ts",
        "import": "./dist/components/WidgetField.js",
        "default": "./dist/components/WidgetField.js"
      },
      "./WidgetCell": {
        "types": "./dist/components/WidgetCell.d.ts",
        "import": "./dist/components/WidgetCell.js",
        "default": "./dist/components/WidgetCell.js"
      },
      "./parseWidgetFields": {
        "types": "./dist/utils/parseWidgetFields.d.ts",
        "import": "./dist/utils/parseWidgetFields.js",
        "default": "./dist/utils/parseWidgetFields.js"
      },
      "./constants": {
        "types": "./dist/constants.d.ts",
        "import": "./dist/constants.js",
        "default": "./dist/constants.js"
      },
      "./CraftjsWidgetField": {
        "types": "./dist/components/CraftjsWidgetField.d.ts",
        "import": "./dist/components/CraftjsWidgetField.js",
        "default": "./dist/components/CraftjsWidgetField.js"
      }
    },
    "main": "./dist/index.js",
    "registry": "https://registry.npmjs.org/",
    "types": "./dist/index.d.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}