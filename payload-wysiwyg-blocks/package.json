{
  "name": "@dexilion/payload-wysiwyg-blocks",
  "version": "3.82.1-alpha.0",
  "description": "WYSIWYG blocks for Payload CMS, providing a Pages collection with dynamic content blocks.",
  "author": "Dexilion",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./WysiwygField": {
      "types": "./src/components/WysiwygField.tsx",
      "import": "./src/components/WysiwygField.tsx",
      "default": "./src/components/WysiwygField.tsx"
    },
    "./LivePreview": {
      "types": "./src/components/LivePreview.tsx",
      "import": "./src/components/LivePreview.tsx",
      "default": "./src/components/LivePreview.tsx"
    },
    "./LivePreviewClient": {
      "types": "./src/components/LivePreviewClient.tsx",
      "import": "./src/components/LivePreviewClient.tsx",
      "default": "./src/components/LivePreviewClient.tsx"
    },
    "./BlockPreview": {
      "types": "./src/components/BlockPreview.tsx",
      "import": "./src/components/BlockPreview.tsx",
      "default": "./src/components/BlockPreview.tsx"
    },
    "./LivePage": {
      "types": "./src/components/LivePage.tsx",
      "import": "./src/components/LivePage.tsx",
      "default": "./src/components/LivePage.tsx"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "peerDependencies": {
    "@dexilion/payload-dynamic-blocks": "workspace:*",
    "@payloadcms/live-preview-react": ">=3",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "payload": "3.82.1"
  },
  "dependencies": {
    "@dexilion/payload-pms": "workspace:*"
  },
  "engines": {
    "node": "^25.9.0 || ^24.14.1 || ^22.22.2 ",
    "pnpm": "^9 || ^10"
  },
  "devDependencies": {
    "@dexilion/payload-dynamic-blocks": "workspace:*",
    "@dexilion/payload-pms": "workspace:*",
    "@eslint/eslintrc": "^3.3.5",
    "@payloadcms/db-mongodb": "3.82.1",
    "@payloadcms/db-postgres": "3.82.1",
    "@payloadcms/db-sqlite": "3.82.1",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "@playwright/test": "1.59.1",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@types/node": "24.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.2",
    "graphql": "^16.8.1",
    "next": "^16.2",
    "npm-run-all2": "^8",
    "payload": "3.82.1",
    "prettier": "^3.8.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "sharp": "^0.34.5",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "scripts": {
    "build": "run-s copyfiles build:types build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./WysiwygField": {
        "types": "./dist/components/WysiwygField.d.ts",
        "import": "./dist/components/WysiwygField.js",
        "default": "./dist/components/WysiwygField.js"
      },
      "./LivePreview": {
        "types": "./dist/components/LivePreview.d.ts",
        "import": "./dist/components/LivePreview.js",
        "default": "./dist/components/LivePreview.js"
      },
      "./LivePreviewClient": {
        "types": "./dist/components/LivePreviewClient.d.ts",
        "import": "./dist/components/LivePreviewClient.js",
        "default": "./dist/components/LivePreviewClient.js"
      },
      "./BlockPreview": {
        "types": "./dist/components/BlockPreview.d.ts",
        "import": "./dist/components/BlockPreview.js",
        "default": "./dist/components/BlockPreview.js"
      },
      "./LivePage": {
        "types": "./dist/components/LivePage.d.ts",
        "import": "./dist/components/LivePage.js",
        "default": "./dist/components/LivePage.js"
      }
    },
    "main": "./dist/index.js",
    "registry": "https://registry.npmjs.org/",
    "types": "./dist/index.d.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}