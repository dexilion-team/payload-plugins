{
  "extends": "../../tsconfig.base.json",
  "exclude": [],
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts"
  ],
  "compilerOptions": {
    "paths": {
      "@payload-config": ["./payload.config.ts"],
      "@dexilion/payload-wysiwyg-blocks": ["../src/index.ts"],
      "@dexilion/payload-pms/RichText": ["../../payload-pms/src/components/RichText/index.tsx"],
      "@dexilion/payload-dynamic-blocks/parseWidgetFields": ["../../payload-dynamic-blocks/src/utils/parseWidgetFields.ts"],
      "@dexilion/payload-dynamic-blocks/RenderField": ["../../payload-dynamic-blocks/src/components/RenderField.tsx"]
    },
    "noEmit": true,
    "emitDeclarationOnly": false
  }
}
