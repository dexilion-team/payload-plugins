{
  "name": "@dexilion/payload-cron-sync",
  "version": "3.74.0",
  "description": "Payload CMS plugin that automatically syncs your job schedules to cron-job.org",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:swc",
    "build:swc": "swc index.ts --out-file dist/index.js && swc index.ts --out-file dist/index.mjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint *.ts",
    "lint:fix": "eslint *.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "payload-plugin",
    "cron",
    "cron-job.org",
    "scheduler",
    "jobs"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.17",
    "@types/node": "^20.0.0",
    "payload": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
